#!/usr/bin/env ion
# SPDX-FileCopyrightText: 2026 Mohamed Hammad <Mohamed.Hammad@SpacecraftSoftware.org>
# SPDX-License-Identifier: GPL-3.0-or-later
#
# fill-keys.ion — Ion (Redox) port of fill-keys.nu.
#
# Fills the MCP config files' placeholder API-key tokens with real values
# directly in their live config paths. Each file is presented with a Y/N
# prompt before modification, so the user controls which hosts get their
# keys filled. Supports unattended (--yes) mode for CI.
#
#   Env var          Fills placeholder           Server
#   CONTEXT7_API_KEY  YOUR_CONTEXT7_API_KEY       context7
#   BRAVE_API_KEY     YOUR_BRAVE_API_KEY          brave-search
#   PERPLEXITY_API_KEY YOUR_PERPLEXITY_API_KEY    perplexity

#
# Requires: sd (cargo install sd / nix run nixpkgs#sd).
#
# Note: Ion eats -h/--help; ION_HIDE_INTERNAL=0 and running `ion help <script>`
#       may show limited help. The --help branch below is best-effort.

fn usage
    echo "Usage: fill-keys.ion [--yes]"
    echo ""
    echo "  --yes       skip all Y/N prompts (auto-yes), for unattended/CI use"
    echo "  -h, --help  show this help"
    echo ""
    echo "Env vars: CONTEXT7_API_KEY, BRAVE_API_KEY, PERPLEXITY_API_KEY"
end

# --- argument parsing ---
let yes_all = 0
let want_yes = 0
let idx = 0
let script = ""
for a in @args
    if test "x$idx" = "x0"
        let script = $a
        let idx = 1
    else if test "x$a" = "x--yes"
        let yes_all = 1
    else if test "x$a" = "x--help"
        usage
        exit 0
    else if test "x$a" = "x-h"
        usage
        exit 0
    end
end

# --- sd preflight ---
let have_sd = 0
if exists -b sd
    let have_sd = 1
end
if test "x$have_sd" = "x0"
    printf 'error: sd not found. Install it: cargo install sd  (or: nix run nixpkgs#sd)\n' > /dev/stderr
    exit 1
end

# --- interactive detection (tty -s is reliable in Ion; test -t is not) ---
let interactive = 0
if test "x$yes_all" = "x0"
    if tty -s
        let interactive = 1
    end
    if exists -s CI
        let interactive = 0
    end
    if exists -s CLAUDECODE
        let interactive = 0
    end
end

# --- prompt helpers ---
fn prompt_yn label:str
    while true
        printf '%s' $label > /dev/tty
        let ans = $(head -n 1 < /dev/tty)
        if test "x$ans" = "xy" || test "x$ans" = "xY" || test "x$ans" = "x"
            return 0
        end
        if test "x$ans" = "xn" || test "x$ans" = "xN"
            return 1
        end
        printf '  Please answer y or n.\n' > /dev/tty
    end
end

fn prompt_val label:str secret:str
    if test "x$secret" = "x1"
        let old = $(stty -g < /dev/tty)
        stty -echo < /dev/tty
        printf '%s' $label > /dev/tty
        let reply = $(head -n 1 < /dev/tty)
        stty $old < /dev/tty
        printf '\n' > /dev/tty
        echo $reply
    else
        printf '%s' $label > /dev/tty
        let reply = $(head -n 1 < /dev/tty)
        echo $reply
    end
end

# --- resolve each token: env var, else prompt, else empty ---
let v_ctx = ""
if exists -s CONTEXT7_API_KEY
    let v_ctx = $CONTEXT7_API_KEY
end
if test -z "$v_ctx" && test "x$interactive" = "x1"
    let v_ctx = $(prompt_val "CONTEXT7_API_KEY [blank to skip]: " "1")
end

let v_brave = ""
if exists -s BRAVE_API_KEY
    let v_brave = $BRAVE_API_KEY
end
if test -z "$v_brave" && test "x$interactive" = "x1"
    let v_brave = $(prompt_val "BRAVE_API_KEY [blank to skip]: " "1")
end

let v_perp = ""
if exists -s PERPLEXITY_API_KEY
    let v_perp = $PERPLEXITY_API_KEY
end
if test -z "$v_perp" && test "x$interactive" = "x1"
    let v_perp = $(prompt_val "PERPLEXITY_API_KEY [blank to skip]: " "1")
end

let filled = 0
let filled_names = ""
if test -n "$v_ctx"
    let filled += 1
    let filled_names ++= " CONTEXT7_API_KEY"
end
if test -n "$v_brave"
    let filled += 1
    let filled_names ++= " BRAVE_API_KEY"
end
if test -n "$v_perp"
    let filled += 1
    let filled_names ++= " PERPLEXITY_API_KEY"
end

# --- live config processing ---
let processed = 0
let skipped_files = 0

# Relative paths under $HOME for each host (label|relpath)
for entry in [ \
    "Antigravity (main)|.gemini/config/mcp_config.json" \
    "Antigravity (alt)|.gemini/antigravity/mcp_config.json" \
    "GitHub Copilot CLI|.copilot/mcp-config.json" \
    "Claude Code|.claude.json" \
    "OpenClaude|.openclaude.json" \
    "Codex CLI|.codex/config.toml" \
    "Grok|.grok/config.toml" \
    "Kimi Code|.kimi-code/config.toml" \
    "Gemini (settings)|.gemini/settings.json" \
    "Gemini (enablement)|.gemini/mcp-server-enablement.json" \
    "Qwen Code|.qwen/settings.json" \
    "OpenCode|.config/opencode/opencode.jsonc" \
    "Mimo Code|.config/mimocode/mimocode.jsonc" \
    "Goose|.config/goose/config.yaml" \
]
    let parts = $(echo $entry | sd '|' '\n')
    let label = $(echo $parts | head -n 1)
    let rel = $(echo $parts | tail -n +2)
    let path = "$HOME/$rel"
    if not test -f "$path"
        printf 'warning: %s not found at %s — skipping\n' $label $path > /dev/stderr
        continue
    end
    if test "x$interactive" = "x1"
        prompt_yn "Fill keys in $label ($path)? [Y/n] "
        if test "x$?" = "x1"
            let skipped_files += 1
            continue
        end
    end
    if test -n "$v_ctx"
        sd -s "YOUR_CONTEXT7_API_KEY" $v_ctx $path
    end
    if test -n "$v_brave"
        sd -s "YOUR_BRAVE_API_KEY" $v_brave $path
    end
    if test -n "$v_perp"
        sd -s "YOUR_PERPLEXITY_API_KEY" $v_perp $path
    end
    let processed += 1
end

printf 'Filled %s of 3 placeholders in %s files' $filled $processed
if test "x$skipped_files" != "x0"
    printf ' (%s declined)' $skipped_files
end
printf '\n'
if test -n "$filled_names"
    printf 'Filled:%s\n' $filled_names
end
