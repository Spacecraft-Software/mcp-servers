{
	"servers": {
		"nixos": {
			"type": "stdio",
			"command": "nix",
			"args": [
				"run",
				"github:utensils/mcp-nixos",
				"--"
			]
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"Authorization": "Bearer ${input:CONTEXT7_API_KEY}"
			}
		},
		"microsoft-learn": {
			"type": "http",
			"url": "https://learn.microsoft.com/api/mcp"
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/spacecraft-software"
			]
		},
		"fetch": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-fetch"
			]
		},
		"engram": {
			"type": "stdio",
			"command": "engram",
			"args": [
				"--db",
				"/home/mj/.gemini/engram.db",
				"mcp"
			]
		},
		"brave-search": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@brave/brave-search-mcp-server"
			],
			"env": {
				"BRAVE_API_KEY": "${input:BRAVE_API_KEY}"
			}
		},
		"sequential-thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"perplexity": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"perplexity-mcp"
			],
			"env": {
				"PERPLEXITY_API_KEY": "${input:PERPLEXITY_API_KEY}"
			}
		},
		"crates": {
			"type": "stdio",
			"command": "crates-mcp"
		}
	},
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "Context7 API key",
			"password": true
		},
		{
			"id": "BRAVE_API_KEY",
			"type": "promptString",
			"description": "Brave Search API key",
			"password": true
		},
		{
			"id": "PERPLEXITY_API_KEY",
			"type": "promptString",
			"description": "Perplexity API key",
			"password": true
		}
	]
}
